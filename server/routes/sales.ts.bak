import { Router } from 'express';
import { PrismaClient } from '@prisma/client';
import { authenticate } from '../middleware/auth';

const router = Router();
const prisma = new PrismaClient();

router.use(authenticate);

router.get('/', async (req, res) => {
  try {
    const sales = await prisma.sale.findMany({
      include: { 
        customer: true, 
        product: true,
        user: { select: { id: true, name: true, email: true } }
      },
      orderBy: { createdAt: 'desc' }
    });
    res.json(sales);
  } catch (error) {
    res.status(500).json({ error: 'Failed to fetch sales' });
  }
});

router.get('/:id', async (req, res) => {
  try {
    const sale = await prisma.sale.findUnique({
      where: { id: req.params.id },
      include: {
        customer: true,
        product: true,
        items: { include: { product: true } },
        user: { select: { id: true, name: true, email: true } }
      },
    });
    res.json(sale);
  } catch (error) {
    res.status(500).json({ error: 'Failed to fetch sale' });
  }
});

router.post('/', async (req, res) => {
  try {
    const sale = await prisma.sale.create({ 
      data: {
        customerId: req.body.customerId,
        productId: req.body.productId,
        userId: (req as any).user.userId,
        quantity: req.body.quantity || 1,
        pricePerBag: req.body.pricePerBag || 0,
        bagType: req.body.bagType || 'SMALL',
        totalAmount: req.body.totalAmount,
        paidAmount: req.body.paidAmount || 0,
        currency: req.body.currency || 'USD',
        paymentStatus: req.body.paymentStatus || 'UNPAID',
        paymentDetails: req.body.paymentDetails ? JSON.stringify(req.body.paymentDetails) : undefined
      },
      include: { 
        customer: true, 
        product: true,
        user: { select: { id: true, name: true, email: true } }
      }
    });
    res.status(201).json(sale);
  } catch (error) {
    console.error('Create sale error:', error);
    res.status(500).json({ error: 'Failed to create sale' });
  }
});

router.put('/:id', async (req, res) => {
  try {
    const sale = await prisma.sale.update({
      where: { id: req.params.id },
      data: {
        quantity: req.body.quantity,
        pricePerBag: req.body.pricePerBag,
        bagType: req.body.bagType,
        totalAmount: req.body.totalAmount,
        paidAmount: req.body.paidAmount,
        currency: req.body.currency,
        paymentStatus: req.body.paymentStatus,
        paymentDetails: req.body.paymentDetails ? JSON.stringify(req.body.paymentDetails) : undefined
      },
      include: { 
        customer: true, 
        product: true,
        user: { select: { id: true, name: true, email: true } }
      }
    });
    res.json(sale);
  } catch (error) {
    console.error('Update sale error:', error);
    res.status(500).json({ error: 'Failed to update sale' });
  }
});

router.delete('/:id', async (req, res) => {
  try {
    await prisma.sale.delete({ where: { id: req.params.id } });
    res.json({ message: 'Sale deleted' });
  } catch (error) {
    res.status(500).json({ error: 'Failed to delete sale' });
  }
});

export default router;